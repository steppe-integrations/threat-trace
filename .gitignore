node_modules/
dist/
build/

# Local env / secrets
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*

# OS / editor cruft
.DS_Store
Thumbs.db
.vscode/
.idea/

# CLI manual hint backend — dev/CI regression tooling, NOT the
# primary product surface (the web app is). Prompt files are
# auto-generated, response files are user-pasted; neither belongs
# in git.
# (cli-manual/examples/ IS committed — canonical reviewable snapshot
#  of what hint:render produces; refresh manually with
#  `npm run hint:render && cp cli-manual/prompts/* cli-manual/examples/`
#  whenever the prompt body or fixture changes.)
cli-manual/prompts/*.md
cli-manual/responses/*.json
!cli-manual/prompts/.gitkeep
!cli-manual/responses/.gitkeep

# Per-recipient sealed key. Generated by `npm run seal-key`,
# inlined into the bundle by Vite, NEVER committed. The
# `prebuild`/`predev` hook in package.json writes a stub
# (`{"sealed": false}`) here on a fresh clone.
src/sealed-key.json

# Email-assembly output. Built by the personal-package scripts in
# scripts/_archive/ and the post-build script; contents are
# recipient-specific artifacts (sealed bundle, personal docx, etc.)
# that don't belong in the public repo. Regenerate locally as needed.
package/

# Personal-package generators. Moved out of scripts/ because they
# reference recipient-specific framing ("two beers / three sentences"
# for a friend who already knew the in-jokes) and an older deck
# filename. Kept locally for re-use on a future personal handoff;
# never committed.
scripts/_archive/

# Personal handoff docx at repo root. The package/ tree (gitignored
# above) gets a regenerated copy with recipient-specific framing;
# this loose copy at root is the personal one and never ships public.
(0)_start-here.docx

# Intermediate PNGs from the JPG-conversion pipeline that produced
# docs/images/*.jpg. Original sources only — kept locally so the
# JPG quality can be re-tuned without re-rendering, never committed.
.tmp_image_originals/

# Internal iteration notes (image-generation reviews, throwaway scratch).
# Useful while iterating; not part of the public artifact set.
docs/openart-review-*.md

# Archive of superseded artifacts (older deck PPTX/PDF, intermediate slide
# image exports, etc.). Kept locally for reference; never shipped public.
docs/_archive/
